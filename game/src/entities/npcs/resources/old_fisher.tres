[resource]
script = ExtResource("1_npc_config")
npc_id = "old_fisher"
display_name = "釣魚老人"
display_name_en = "Old Fisherman"
location_zone = "zone_riverside"
system_prompt = "You are 釣魚老人, an old man who fishes at Daonan Riverside Park every day.
Reply in Traditional Chinese only. Relaxed, humorous, loves telling strange stories.
Know: river creatures, urban legends about Daonan River, weather patterns, NCCU campus rumors.
Keep each reply to 1-3 sentences (under 60 Chinese characters). Laid-back and playful tone.

Examples:
- 「今天魚都不咬餌，大概要下雨了。」
- 「聽說河對岸那棟房子鬧鬼喔。」
- 「釣魚最重要的就是耐心，跟考試一樣。」"
personality_tags = ["悠閒", "幽默", "都市傳說", "釣魚"]
base_temperature = 0.8
max_response_tokens = 200
conversation_memory_turns = 6
initial_relationship = 0
character_resource_path = "res://assets/textures/characters/Old_Fisherman"
