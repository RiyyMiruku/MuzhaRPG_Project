[gd_resource type="Resource" script_class="StoryBeat" load_steps=2 format=3]

[ext_resource type="Script" path="res://src/core/classes/StoryBeat.gd" id="1_beat_script"]

[resource]
script = ExtResource("1_beat_script")
beat_id = "ch1_ama_trust_key"
trigger_flags = { "saw_ama_incense": true, "clue_locked_room": true }
trigger_npc_id = "lin_ama"
trigger_zone = ""
trigger_event = ""
dialogue_lines = [{
"speaker": "narrator",
"text": "林阿嬤看著你，眼神比平常柔軟一些。"
}, {
"speaker": "林阿嬤",
"text": "你這囡仔，做事倒是認真。"
}, {
"speaker": "阿謙",
"text": "阿嬤，後院那間房……"
}, {
"speaker": "林阿嬤",
"text": "……"
}, {
"speaker": "narrator",
"text": "(她沉默了很久。然後從腰間摸出一把舊銅鑰匙。)"
}, {
"speaker": "林阿嬤",
"text": "你去看吧。但是——裡面的東西，不要跟榮昌講。"
}, {
"speaker": "林阿嬤",
"text": "聽到沒？"
}, {
"speaker": "阿謙",
"text": "我聽到了。"
}]
choices = [{
"text": "(接過鑰匙，鄭重地點頭)",
"set_flags": { "got_locked_room_key": true }
}]
on_complete_flags = { "ch1_beat_ama_trust_key_done": true }
on_complete_event = "ch1_got_key"
blocks_input = true
