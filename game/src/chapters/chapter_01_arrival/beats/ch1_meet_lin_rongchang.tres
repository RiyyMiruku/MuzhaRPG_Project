[gd_resource type="Resource" script_class="StoryBeat" load_steps=2 format=3]

[ext_resource type="Script" path="res://src/core/classes/StoryBeat.gd" id="1_beat_script"]

[resource]
script = ExtResource("1_beat_script")
beat_id = "ch1_meet_lin_rongchang"
trigger_flags = { "first_time_traveled": true }
trigger_npc_id = "lin_rongchang"
trigger_zone = ""
dialogue_lines = [{
"speaker": "林榮昌",
"text": "你還沒回答我。怎麼進來的?藥行不是隨便人都能進的。"
}, {
"speaker": "narrator",
"text": "(阿謙腦中飛快地想著該怎麼解釋。說真話絕對不行。)"
}, {
"speaker": "阿謙",
"text": "對不起,我是 —— 我是你的遠房表親的兒子,從南部上來找工作。"
}, {
"speaker": "阿謙",
"text": "朋友介紹說這裡可能缺人手,我就直接進來了。對不起,門沒鎖,我以為..."
}, {
"speaker": "林榮昌",
"text": "遠房表親?哪邊的?"
}, {
"speaker": "阿謙",
"text": "高雄那邊的。我也不太記得族譜,我爸沒講過細節..."
}, {
"speaker": "林榮昌",
"text": "..."
}, {
"speaker": "narrator",
"text": "(林榮昌沉默地看了你很久。)"
}, {
"speaker": "林榮昌",
"text": "我這邊確實缺人。你叫什麼名字?"
}, {
"speaker": "阿謙",
"text": "阿謙。林...林思謙。"
}, {
"speaker": "林榮昌",
"text": "...林家的?"
}, {
"speaker": "阿謙",
"text": "(完了。)是的。"
}, {
"speaker": "林榮昌",
"text": "好。先幫忙整理藥櫃。今晚住二樓那間空房。"
}, {
"speaker": "林榮昌",
"text": "別問太多。"
}]
choices = [{
"text": "(點頭,默默開始工作)",
"set_flags": { "lin_rongchang_accepted_fake_identity": true }
}, {
"text": "(想再追問一句,但忍住了)",
"set_flags": { "lin_rongchang_accepted_fake_identity": true, "almost_revealed_identity": true }
}]
on_complete_flags = { "ch1_beat_meet_lin_rongchang_done": true }
on_complete_event = "ch1_started_living_in_pharmacy"
blocks_input = true
