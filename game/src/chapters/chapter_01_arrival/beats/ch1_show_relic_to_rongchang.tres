[resource]
script = ExtResource("1_beat_script")
beat_id = "ch1_show_relic_to_rongchang"
trigger_flags = { "found_ronghua_relic": true }
trigger_npc_id = "lin_rongchang"
trigger_zone = ""
trigger_event = ""
dialogue_lines = [{
"speaker": "narrator",
"text": "(阿謙把皮革筆記本放在櫃台上。)"
}, {
"speaker": "林榮昌",
"text": "……你從哪裡拿到的？"
}, {
"speaker": "narrator",
"text": "(他的手指碰到筆記本封面的那兩個字，停住了。)"
}, {
"speaker": "阿謙",
"text": "後院那間房。"
}, {
"speaker": "林榮昌",
"text": "誰給你鑰匙的？"
}, {
"speaker": "阿謙",
"text": "……阿嬤。"
}, {
"speaker": "narrator",
"text": "(林榮昌閉上眼睛。很久很久。)"
}, {
"speaker": "林榮昌",
"text": "你不該看到這個的。"
}, {
"speaker": "林榮昌",
"text": "但既然看到了……晚上再說。"
}]
choices = [{
"text": "(沉默等待夜晚到來)",
"set_flags": { "finale_night_ready": true }
}]
on_complete_flags = { "ch1_beat_show_relic_done": true }
on_complete_event = "ch1_relic_shown"
blocks_input = true
