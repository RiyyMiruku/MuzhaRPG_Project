[gd_resource type="Resource" script_class="StoryBeat" load_steps=2 format=3]

[ext_resource type="Script" path="res://src/core/classes/StoryBeat.gd" id="1_beat_script"]

[resource]
script = ExtResource("1_beat_script")
beat_id = "ch1_xiaowei_curiosity"
trigger_flags = { "ch1_beat_meet_lin_rongchang_done": true }
trigger_npc_id = "lin_xiaowei"
trigger_zone = ""
trigger_event = ""
dialogue_lines = [{
"speaker": "林小威",
"text": "欸，你是新來的那個？我爸叫你來幫忙的？"
}, {
"speaker": "阿謙",
"text": "對，我叫阿謙。"
}, {
"speaker": "林小威",
"text": "歡迎歡迎。反正我是不想顧這間店啦。"
}, {
"speaker": "narrator",
"text": "(林小威壓低了聲音。)"
}, {
"speaker": "林小威",
"text": "欸，你住二樓那間對不對？隔壁那間永遠鎖著的，你有沒有覺得很奇怪？"
}, {
"speaker": "阿謙",
"text": "那間房是誰的？"
}, {
"speaker": "林小威",
"text": "不知道。問誰都不講。我從小就看那扇門鎖著。"
}, {
"speaker": "林小威",
"text": "但我爸每隔幾天會進去。不知道在幹嘛。"
}, {
"speaker": "林小威",
"text": "你如果發現什麼，跟我說一聲啊。"
}]
choices = [{
"text": "好，有什麼消息互相通報。",
"set_flags": { "xiaowei_ally": true }
}, {
"text": "我才剛來，還是少管閒事吧。",
"set_flags": { "xiaowei_declined": true }
}]
on_complete_flags = { "ch1_beat_xiaowei_curiosity_done": true, "clue_locked_room": true }
on_complete_event = "ch1_xiaowei_talked"
blocks_input = true
