; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Muzha RPG"
config/description="台灣木柵在地 RPG 遊戲 - AI 驅動對話系統"
config/version="0.1.0"
run/main_scene="res://src/maps/main_world.tscn"
config/features=PackedStringArray("4.6")
config/author="Muzha RPG Team"

[autoload]

GameManager="*res://src/autoload/GameManager.gd"
StoryManager="*res://src/autoload/StoryManager.gd"
AIClient="*res://src/autoload/AIClient.gd"
QuestManager="*res://src/autoload/QuestManager.gd"
EventBus="*res://src/autoload/EventBus.gd"
UIManager="*res://src/autoload/UIManager.gd"

[debug]

gdscript/warnings/unused_argument=1

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/stretch/mode="canvas_items"

