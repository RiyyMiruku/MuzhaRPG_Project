# =================================================================
# 1. Godot 引擎相關 (核心過濾)
# =================================================================
game/.godot/
game/*.tmp
game/*.remap
game/*.translation
*.import
*.uid
game/export_presets.cfg
game/build/
game/dist/

# 遊戲執行時生成的存檔與日誌
game/saves/
game/logs/

# =================================================================
# 2. AI 引擎與模型檔案 (防止倉庫爆炸)
# =================================================================
# 排除推論引擎執行檔與 DLL (llama-server 相關)
ai_engine/engines/*
!ai_engine/engines/.gitkeep

# 個人化設定（保留 config.default.json 作為模板；config.json 為使用者本地覆寫值）
ai_engine/config.json

# 排除大型模型檔案 (GGUF, Safetensors 等)
*.gguf
*.bin
*.safetensors
ai_engine/models/*
!ai_engine/models/.gitkeep

# =================================================================
# 3. Python 測試環境 (用於 LLM 測試腳本)
# =================================================================
**/__pycache__/
**/*.py[cod]
**/*.egg-info/
.venv/
venv/
ENV/
.env

# =================================================================
# 4. 編輯器與作業系統 (環境清潔)
# =================================================================
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

.DS_Store
Thumbs.db
*.swp
*.swo
*~